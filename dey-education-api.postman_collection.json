        { "name": "Subcategories", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{base_url}}/subcategories?per_page=20" } },
        { "name": "Teachers", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{base_url}}/teachers?per_page=20" } },
        { "name": "Teacher Detail", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{base_url}}/teachers/{{resource_id}}" } },
        { "name": "Testimonials", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{base_url}}/testimonials?per_page=20" } }
